FLASK_SECRET_KEY=replace-with-a-long-random-secret

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=malaria_database
# Optional Railway-style connection string. If set, it takes priority over MYSQL_HOST/PORT/USER/PASSWORD.
# MYSQL_URL=mysql://root:your-mysql-password@host:port/railway

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

APP_BASE_URL=http://127.0.0.1:5000
PROFILE_UPLOAD_DIR=static/uploads/profile_pics
