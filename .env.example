FLASK_SECRET_KEY=replace-with-a-long-random-secret

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=malaria_database

